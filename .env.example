# Copy this file to .env and fill in your values. NEVER commit .env.

# --- Backend ---
APP_ENV=development
APP_NAME=Kraken Trading Agent

# Use Postgres in production, sqlite for local dev
# DATABASE_URL=postgresql+psycopg://kta:kta@db:5432/kta
DATABASE_URL=sqlite:///./trading_agent.db

# JWT signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please-generate-a-random-secret
JWT_EXPIRES_MINUTES=480

# Fernet encryption key for Kraken API credentials at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, a key is derived from JWT_SECRET (DEV ONLY).
ENCRYPTION_KEY=

# Kraken
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_REQUEST_TIMEOUT_SECONDS=15

# Risk-engine defaults (per-user values can be edited from the Settings page)
DEFAULT_MAX_ORDER_NOTIONAL_USD=1000
DEFAULT_DRY_RUN=true
DEFAULT_TRADING_ENABLED=true
LARGE_ORDER_THRESHOLD_USD=5000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Rate limit (slowapi syntax)
RATE_LIMIT_PER_MINUTE=60/minute

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
